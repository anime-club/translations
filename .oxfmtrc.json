{
  "ignorePatterns": [
    // our ".js & .jsx" files are built-files that should not be formatted
    "**/*.js",
    "**/*.jsx"
  ],
  "arrowParentheses": "always",
  "trailingCommas": "all",
  "indentWidth": 2,
  "semi": false,
  "useTabs": false,
  "bracketSpacing": true,
  "sortImports": {
    "groups": ["builtin", "external", "internal", ["parent", "sibling", "index"], "unknown"],
    "newlinesBetween": true,
    "order": "asc",
    "ignoreCase": true
  }
}
